{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "files": {
    "includes": ["src/**/*.ts", "scripts/**/*.ts", "db/**/*.ts"]
  }
}
