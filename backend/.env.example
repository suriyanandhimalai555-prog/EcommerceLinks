# ── Database ──────────────────────────────────────────────────────────────────
# Required in production. Local default: postgresql://avg:avg@localhost:5432/avg
DATABASE_URL=postgresql://avg:avg@localhost:5432/avg

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required in production. Local default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — must NOT be the dev default below.
# Generate with: openssl rand -hex 64
JWT_SECRET=dev-secret-change-in-prod

# ── Payment webhook ───────────────────────────────────────────────────────────
# REQUIRED in production — must match the payment gateway's shared secret.
# If empty in dev, the header check is skipped (insecure; do not leave empty in prod).
WEBHOOK_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins. In production set to the exact
# Cloudflare Pages URL (e.g. https://avg-portal.pages.dev).
CORS_ORIGINS=http://localhost:5173 http://localhost:3000

# ── Money (override only for testing — must match DB constraints) ─────────────
# PAIR_BONUS_PAISE must equal the pairs.bonus_amount DEFAULT (1000.00 rupees = 100000 paise)
# CUTOFF_CAP_PAISE must equal the cutoffs.chk_cap  CHECK   (100000.00 rupees = 10000000 paise)
PAIR_BONUS_PAISE=100000
CUTOFF_CAP_PAISE=10000000

# ── Tax / payout thresholds ───────────────────────────────────────────────────
GST_PCT=18
TDS_PCT=5
MIN_PAYOUT_PAISE=50000

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional — email features degrade gracefully when SMTP_HOST is unset.
# Management toggles in /admin/settings control whether welcome/OTP emails fire.
# Example values below work with most SMTP hosts (Zoho, cPanel, Gmail App Password, etc.)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=support@agilavertiglobal.com
SMTP_PASS=your-smtp-password
# Set SMTP_SECURE=true only for port 465 (SSL); leave false for port 587 (STARTTLS).
SMTP_SECURE=false
# The "From" address shown to recipients.
EMAIL_FROM=Agila Vetri Groups <support@agilavertiglobal.com>
