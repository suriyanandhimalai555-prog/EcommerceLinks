{
  "name": "avg-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:workers": "tsx src/workers/all.ts",
    "start:api": "node dist/src/api/server.js",
    "start:workers": "node dist/src/workers/all.js",
    "migrate": "tsx db/migrate.ts",
    "lint": "biome check src/",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seedRoot.ts",
    "seed:management": "tsx scripts/seedManagement.ts",
    "reset": "tsx scripts/reset.ts",
    "revert:qualification": "tsx scripts/revertQualification.ts",
    "simulate": "tsx scripts/simulate.ts",
    "worker:outbox": "tsx src/workers/outboxRelay.ts",
    "worker:fanout": "tsx src/workers/fanout.ts",
    "worker:counter": "tsx src/workers/counterPair.ts",
    "worker:paircomplete": "tsx src/workers/pairComplete.ts",
    "worker:qualification": "tsx src/workers/qualification.ts",
    "worker:ledger": "tsx src/workers/ledger.ts",
    "worker:rank": "tsx src/workers/rank.ts",
    "worker:cutoff": "tsx src/workers/cutoff.ts",
    "worker:payout": "tsx src/workers/payout.ts",
    "worker:reconciler": "tsx src/workers/reconciler.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-presigned-post": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "argon2": "^0.40.3",
    "big.js": "^6.2.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "luxon": "^3.5.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/big.js": "^6.2.2",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
